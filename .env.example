# Copy this file to ".env" for local development and fill in the values.
# On Render, set these in the service's "Environment" settings instead of committing them.

# MongoDB Atlas connection string.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Port the server listens on. Render injects PORT automatically, so this is only
# used for local development. Defaults to 5000 if unset (see app.js).
PORT=5000
